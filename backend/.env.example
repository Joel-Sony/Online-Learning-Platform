# =============================================================
# Online Learning Platform — Environment Variables Template
# Copy this file to .env and fill in your own values.
# NEVER commit .env to Git. This file IS safe to commit.
# =============================================================

# Django
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgres://online_user:online_password@db:5432/online_platform

# Redis (for WebSockets / Django Channels)
REDIS_URL=redis://redis:6379/1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# =============================================================
# STRIPE — TEST MODE ONLY
# Get keys from: https://dashboard.stripe.com/test/apikeys
# (make sure Test Mode toggle is ON in top-right)
# =============================================================
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Get webhook secret by running: stripe listen --forward-to localhost:8000/api/webhooks/stripe/
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# =============================================================
# PAYPAL — SANDBOX MODE ONLY
# Get credentials from: https://developer.paypal.com/dashboard/applications/sandbox
# 1. Create an App  2. Copy Client ID + Secret below
# 3. Set PAYPAL_CURRENCY to match your sandbox buyer account's currency
#    (find it at https://developer.paypal.com/dashboard/accounts)
# =============================================================
PAYPAL_CLIENT_ID=REPLACE_ME
PAYPAL_CLIENT_SECRET=REPLACE_ME
PAYPAL_CURRENCY=USD

# =============================================================
# EMAIL — Mailpit (Docker, catches all email locally)
# View inbox at http://localhost:8025
# =============================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@onlinelearning.com
